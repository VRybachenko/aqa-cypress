{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "allowJs": true,
    "types": ["cypress", "node"]
  },
  "include": [
    "../**/*.js",
    "../**/*.ts",
    "../**/*.d.ts"
  ]
}